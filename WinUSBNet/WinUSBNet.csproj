<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <PropertyGroup>
    <AssemblyVersion>2.1.4.0</AssemblyVersion>
    <FileVersion>2.1.4.0</FileVersion>
    <Version>2.1.4</Version>
    <TargetFrameworks>net48;net481;net10.0-windows</TargetFrameworks>
    <RootNamespace>MadWizard.WinUSBNet</RootNamespace>
    <UseWindowsForms>true</UseWindowsForms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PackageTags>WinUSB USB</PackageTags>
    <PackageProjectUrl>https://github.com/FrankeCoffee/winusbnet</PackageProjectUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>FrankeCsTools.WinUSBNet</PackageId>
    <RepositoryUrl>https://github.com/FrankeCoffee/winusbnet</RepositoryUrl>
    <Description>WinUSBNet is a .NET class library that provides easy access to the WinUSB API from C#, VB.NET and other .NET languages.</Description>
    <Copyright>Copyright © 2010 - 2020 by Thomas Bleeker (MadWizard.org)</Copyright>
    <Company>Madwizard.org</Company>
    <Authors>Thomas Bleeker</Authors>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <SignAssembly>True</SignAssembly>
    <AssemblyOriginatorKeyFile>WinUSBNet.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>
  <ItemGroup>
    <Resource Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  
</Project>